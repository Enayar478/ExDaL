# ─────────────────────────────────────────────────────────────────────────────
#  ExDaL — Variables d'environnement
#  Copiez ce fichier en `.env.local` (dev) et renseignez chaque valeur.
#  En production, saisissez ces mêmes variables dans Vercel :
#  Project → Settings → Environment Variables.
#  AUCUN secret ne doit être committé. `.env.local` est ignoré par git.
# ─────────────────────────────────────────────────────────────────────────────


# ── PUBLIC (exposé au navigateur, préfixe NEXT_PUBLIC_) ──────────────────────

# URL canonique du site en production. Sert au SEO, aux metadata et au sitemap.
# Valeur : https://exdal.fr  (en préproduction, l'URL Vercel *.vercel.app)
NEXT_PUBLIC_SITE_URL=https://exdal.fr

# Lien de réservation Cal.com. Deux formats acceptés :
#   - slug  « utilisateur/type-evenement »  ex. exdal/echange-20min
#   - URL complète                          ex. https://cal.com/exdal/echange-20min
# Où le trouver : https://app.cal.com → Event Types → votre événement 20 min →
#   bouton « Copy link ». Créez un event type d'une durée de 20 minutes.
CAL_LINK=exdal/echange-20min


# ── SUPABASE (stockage des leads — votre donnée) ─────────────────────────────

# URL du projet Supabase.
# Où : https://app.supabase.com → votre projet → Settings → Data API → Project URL
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co

# Clé service_role (SECRET — accès complet, contourne la RLS). SERVEUR UNIQUEMENT.
# Où : Settings → API Keys → `service_role` (Reveal). Ne jamais l'exposer côté client.
SUPABASE_SERVICE_ROLE_KEY=eyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX


# ── RESEND (emails de confirmation & notification) ───────────────────────────

# Clé API Resend.
# Où : https://resend.com → API Keys → Create API Key (droit « Sending access »).
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXX

# Adresse d'expédition (doit appartenir à un domaine vérifié dans Resend).
# Où : https://resend.com → Domains → ajoutez exdal.fr et vérifiez les DNS.
# Ex. bonjour@exdal.fr  ou  contact@exdal.fr
RESEND_FROM_EMAIL=bonjour@exdal.fr

# Adresse qui reçoit la notification interne à chaque nouveau rendez-vous.
# Mettez votre adresse personnelle/professionnelle.
NOTIFICATION_EMAIL=vous@exemple.fr


# ── CAL.COM WEBHOOK (sécurise la réception des réservations) ─────────────────

# Secret de signature du webhook Cal.com (HMAC-SHA256).
# Où : https://app.cal.com → Settings → Developer → Webhooks → créez un webhook
#   pointant vers  https://exdal.fr/api/cal-webhook , événement BOOKING_CREATED,
#   puis renseignez un « Secret » et recopiez-le ici.
# REQUIS dès qu'un webhook est branché : sans ce secret, l'endpoint /api/cal-webhook
# rejette toute requête (fail-closed) — jamais d'endpoint ouvert acceptant de faux bookings.
CAL_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXX


# ── NEWSLETTER « LUMEN » (double opt-in RGPD) ───────────────────────────────

# Secret HMAC-SHA256 pour signer les tokens de confirmation d'inscription.
# REQUIS pour activer la newsletter. Sans ce secret, /api/newsletter renvoie 503.
# Générer avec : openssl rand -hex 32
NEWSLETTER_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX


# ── RATE LIMITING DURABLE (Upstash Redis — OPTIONNEL mais recommandé en prod) ──

# Sans ces deux variables, le rate-limit retombe sur un repli EN MÉMOIRE
# (best-effort, non partagé entre instances serverless → contournable). Avec
# Upstash, le compteur est partagé entre toutes les instances → limite réelle.
# Où : https://console.upstash.com → Create Database (Redis, région EU) →
#   onglet « REST API » → copiez UPSTASH_REDIS_REST_URL et UPSTASH_REDIS_REST_TOKEN.
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
